# === База данных ===
# SQLite (по умолчанию, для разработки):
# DATABASE_URL=sqlite:///./backend/data/ticket_system.db
# PostgreSQL (для продакшена):
# DATABASE_URL=postgresql://user:password@host:5432/ticket_system

# === Безопасность ===
# Обязательно смените в продакшене!
SECRET_KEY=change-me-in-production-super-secret-key

# === Сервер ===
HOST=0.0.0.0
PORT=8000

# === AI-ассистент ===
# OPENAI_API_KEY=sk-...
# AI_MODEL=gpt-4

# === Уведомления ===
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASSWORD=your-password
# TELEGRAM_BOT_TOKEN=...
# SENDGRID_API_KEY=...
